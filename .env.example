# ── Database ──
SCORING_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/scoring

# ── API Auth ──
SCORING_API_KEYS=dev-key-1,dev-key-2
SCORING_ADMIN_API_KEY=admin-secret-key

# ── Rate Limiting ──
SCORING_RATE_LIMIT_REQUESTS=60
SCORING_RATE_LIMIT_WINDOW_SECONDS=60
SCORING_MAX_REQUEST_BODY_BYTES=1048576

# ── Environment ──
SCORING_ENV=dev
SCORING_LOG_LEVEL=INFO
SCORING_LOG_JSON=true
SCORING_DB_ECHO=false
SCORING_FALLBACK_ON_ERROR=true

# ── Observability ──
SCORING_OTEL_ENABLED=false
SCORING_OTEL_SERVICE_NAME=scoring-service
SCORING_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Idempotency ──
SCORING_ENABLE_IDEMPOTENCY=true
SCORING_IDEMPOTENCY_TTL_SECONDS=86400
SCORING_DEDUP_WINDOW_SECONDS=3600

# ── Job Queue ──
SCORING_ENABLE_JOBS=true
SCORING_JOB_MAX_ATTEMPTS=5
SCORING_JOB_BACKOFF_BASE_SECONDS=2.0
SCORING_JOB_BACKOFF_MAX_SECONDS=300.0
SCORING_JOB_BACKOFF_JITTER=true
SCORING_JOB_STALE_LOCK_TIMEOUT_SECONDS=600
SCORING_JOB_LEASE_DURATION_SECONDS=300
SCORING_JOB_POLL_INTERVAL_SECONDS=5.0
SCORING_JOB_BATCH_SIZE=10

# ── Outbox ──
SCORING_ENABLE_OUTBOX=true
SCORING_OUTBOX_DISPATCH_INTERVAL_SECONDS=5.0
SCORING_OUTBOX_BATCH_SIZE=20
SCORING_OUTBOX_MAX_DISPATCH_ATTEMPTS=5

# ── Circuit Breaker ──
SCORING_ENABLE_CIRCUIT_BREAKER=true
SCORING_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
SCORING_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=60
SCORING_CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3

# ── Source Protection ──
SCORING_ENABLE_SOURCE_PROTECTION=true
SCORING_SOURCE_QUARANTINE_ERROR_THRESHOLD=10
SCORING_SOURCE_QUARANTINE_WINDOW_SECONDS=300
SCORING_SOURCE_QUARANTINE_DURATION_SECONDS=3600

# ── Notifications (optional) ──
SCORING_NOTIFICATION_WEBHOOK_URL=
SCORING_NOTIFICATION_WEBHOOK_SECRET=

# ── Security ──
SCORING_CORS_ALLOWED_ORIGINS=*
SCORING_REDACT_FIELDS=password,secret,token,api_key,authorization
