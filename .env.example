SCORING_APP_NAME=scoring-service
SCORING_ENV=dev
SCORING_LOG_LEVEL=INFO
SCORING_LOG_JSON=true
SCORING_MIN_SCORE=0
SCORING_MAX_SCORE=100
SCORING_MAX_TEXT_WEIGHT_PER_FIELD=10
SCORING_MAX_COLLECTION_BONUS=8
SCORING_MAX_NESTED_BONUS=12
SCORING_NUMERIC_MULTIPLIER=0.10
SCORING_ITEM_WEIGHT=2.0
SCORING_COLLECTION_WEIGHT=0.75
SCORING_NESTED_WEIGHT=1.5
SCORING_TRUE_FLAG_BONUS=2.0
SCORING_EMIT_METRICS=true
SCORING_EMIT_ANALYTICS=true
SCORING_PRETTY_JSON_INDENT=2
SCORING_FALLBACK_ON_ERROR=true
SCORING_REVIEWER_EXCELLENT_THRESHOLD=80
SCORING_REVIEWER_APPROVED_THRESHOLD=50
SCORING_REVIEWER_MANUAL_REVIEW_THRESHOLD=20
SCORING_MAX_DIAGNOSTICS=20
SCORING_API_HOST=0.0.0.0
SCORING_API_PORT=8000
